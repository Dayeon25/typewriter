rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    match /rooms/{roomId} {
      allow read, write: if true;
      match /{allPaths=**} {
        allow read, write: if true;
      }
    }
  }
}
